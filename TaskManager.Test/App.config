<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="ConnSqliteStr" connectionString="Data Source=./data/Data.db;Version=3" providerName="System.Data.SQLite" />
	</connectionStrings>
	<appSettings>
		<add key="ServerType" value="Sqlite" />
	</appSettings>
</configuration>